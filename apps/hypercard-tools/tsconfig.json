{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "react": ["../../packages/os-core/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["../../packages/os-core/node_modules/@types/react/jsx-runtime.d.ts"],
      "react/jsx-dev-runtime": ["../../packages/os-core/node_modules/@types/react/jsx-dev-runtime.d.ts"],
      "@go-go-golems/os-shell": ["../../packages/os-shell/src"],
      "@go-go-golems/os-shell/*": ["../../packages/os-shell/src/*"],
      "@go-go-golems/os-core": ["../../packages/os-core/src"],
      "@go-go-golems/os-core/*": ["../../packages/os-core/src/*"],
      "@go-go-golems/os-scripting": ["../../packages/os-scripting/src"],
      "@go-go-golems/os-scripting/*": ["../../packages/os-scripting/src/*"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../../packages/os-shell" },
    { "path": "../../packages/os-core" },
    { "path": "../../packages/os-scripting" }
  ]
}
