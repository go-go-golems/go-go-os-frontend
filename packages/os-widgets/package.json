{
  "name": "@go-go-golems/os-widgets",
  "version": "0.2.0",
  "description": "Reusable rich React widgets, widget primitives, Redux state helpers, and theme CSS from go-go-os.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "author": "Manuel Odendahl",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/go-go-golems/go-go-os-frontend.git",
    "directory": "packages/os-widgets"
  },
  "homepage": "https://github.com/go-go-golems/go-go-os-frontend/tree/main/packages/os-widgets#readme",
  "bugs": {
    "url": "https://github.com/go-go-golems/go-go-os-frontend/issues"
  },
  "files": [
    "**/*.js",
    "**/*.d.ts",
    "**/*.css",
    "**/*.vm.js",
    "**/*.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./src/index.ts",
    "./theme": "./src/theme/index.ts",
    "./launcher": "./src/launcher/modules.tsx"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -b",
    "build:dist": "node ../../scripts/packages/build-dist.mjs",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@go-go-golems/os-repl": "workspace:*"
  },
  "peerDependencies": {
    "@go-go-golems/os-shell": "workspace:*",
    "@go-go-golems/os-core": "workspace:*",
    "@reduxjs/toolkit": "^2.0.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "react-redux": "^9.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "keywords": [
    "react",
    "widgets",
    "theme",
    "redux",
    "desktop",
    "go-go-golems"
  ],
  "sideEffects": [
    "**/*.css",
    "./theme/index.js",
    "./theme/*.css"
  ],
  "peerDependenciesMeta": {
    "@go-go-golems/os-shell": {
      "optional": true
    }
  }
}
